{
  "database-url-var": "DATABASE_URL",
  "migrations-dir": "migrations",
  "migrations-table": "pgmigrations",
  "migration-file-language": "js",
  "dir": "migrations",
  "check-order": true,
  "ignore-pattern": "\\..*",
  "schema": "public",
  "decamelize": false,
  "disable-comments": false,
  "verbose": true,
  "reject-unauthorized": false
}
