# Database
DATABASE_URL=postgresql://rmt_user:rmt_password@localhost:5432/rmt_dev

# Authentication
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRATION=24h

# Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Server
PORT=4000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug
